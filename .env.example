# FileZilla FTP Server — deployment credentials
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.

FTP_HOST=your-ftp-host.example.com
FTP_PORT=21
FTP_USER=your-username
FTP_PASSWORD=your-password

# Remote directory on the FTP server (where the app is deployed)
# For https://iis.denrcar.com/denr_watershed/#/map this should be /denr_watershed
FTP_REMOTE_DIR=/denr_watershed

# Set to "true" to use passive mode (recommended for most servers)
FTP_PASSIVE=true
