{
  "name": "geoCradle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/compress-geojson.mjs",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write src/",
    "preview": "vite preview",
    "postinstall": "node scripts/patch-vectorgrid.mjs",
    "deploy": "node scripts/deploy-ftp.mjs",
    "deploy:upload-only": "node scripts/deploy-ftp.mjs --skip-build",
    "deploy:update": "node scripts/update-deploy.mjs",
    "deploy:watch": "node scripts/update-deploy.mjs --watch",
    "deploy:now": "node scripts/update-deploy.mjs --deploy-only",
    "deploy-gui": "node geoJSONUpdater/server.mjs"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@turf/turf": "^7.3.5",
    "basic-ftp": "^6.0.1",
    "dotenv": "^17.4.2",
    "geojson-vt": "^4.0.3",
    "leaflet": "^1.9.4",
    "leaflet.vectorgrid": "^1.3.0",
    "pmtiles": "^4.4.1",
    "protomaps-leaflet": "^5.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.0",
    "tesseract.js": "^7.0.0",
    "topojson-client": "^3.1.0",
    "topojson-server": "^3.0.1",
    "vt-pbf": "^3.1.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "express": "^5.2.1",
    "ftp-srv": "^4.6.3",
    "globals": "^17.7.0",
    "oxlint": "^1.69.0",
    "pg": "^8.22.0",
    "prettier": "^3.8.4",
    "puppeteer": "^25.2.1",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1"
  }
}
